# Optional: direct Ollama cloud API mode.
# Local Ollama at http://127.0.0.1:11434 is used when this is empty.
OLLAMA_API_KEY=

# Optional model overrides.
# Your local Ollama currently exposes glm-5.1:cloud and qwen2.5-coder:latest.
OLLAMA_CLOUD_MODEL=glm-5.1:cloud
OLLAMA_CODER_MODEL=qwen2.5-coder:latest
OLLAMA_TIMEOUT_MS=300000
